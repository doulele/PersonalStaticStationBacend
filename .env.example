# 服务端口
PORT=3001

# 阿里云百炼 DashScope API Key（Qwen3-TTS 语音合成，可选，未配置时使用浏览器内置 TTS）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_KEY

# 阿里云百炼业务空间 ID（语音克隆/声音复刻需要）
# 获取地址：https://dashscope.console.aliyun.com → 业务空间 → 空间ID
DASHSCOPE_WORKSPACE_ID=YOUR_WORKSPACE_ID

# 聚合数据彩票 API Key（可选，未配置时返回 mock 数据）
JUHE_LOTTERY_KEY=YOUR_JUHE_KEY
